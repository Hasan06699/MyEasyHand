# Application
NODE_ENV=development
PORT=5051
API_VERSION=v1
APP_NAME=MyEasyHand API
APP_URL=http://localhost:5051

# MongoDB
# Local dev (npm run dev): mongodb://localhost:27017/myeasyhand
# Docker API container: mongodb://mongodb:27017/myeasyhand
MONGODB_URI=mongodb://localhost:27017/myeasyhand
MONGODB_DB_NAME=myeasyhand

# Redis
# Local dev: localhost | Docker: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-to-a-long-random-access-secret
JWT_REFRESH_SECRET=change-me-to-a-long-random-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@myeasyhand.in

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# NSFW image moderation (all image uploads on server)
NSFW_MODERATION_ENABLED=true
NSFW_MODEL=InceptionV3
NSFW_PORN_THRESHOLD=0.25
NSFW_HENTAI_THRESHOLD=0.25
NSFW_SEXY_THRESHOLD=0.6
NSFW_COMBINED_THRESHOLD=0.35
NSFW_TOP_CLASS_THRESHOLD=0.2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: dedicated key for admin-recoverable customer passwords
# PASSWORD_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:3031,http://localhost:8081

SUPER_ADMIN_EMAIL=admin@myeasyhand.in
SUPER_ADMIN_PASSWORD=Admin@123456
