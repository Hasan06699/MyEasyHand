    "@types/lodash": "4.17.9",
    "@types/node": "22.7.4",
    "@types/react": "^19.1.4",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "9.21.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
